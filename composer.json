{
    "name": "philiprehberger/laravel-slug-generator",
    "description": "Automatic slug generation for Eloquent models with scoped uniqueness, history, and transliteration",
    "type": "library",
    "keywords": [
        "laravel",
        "slug",
        "eloquent",
        "seo",
        "url"
    ],
    "homepage": "https://github.com/philiprehberger/laravel-slug-generator",
    "license": "MIT",
    "authors": [
        {
            "name": "Philip Rehberger",
            "email": "me@philiprehberger.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "phpstan/extension-installer": "^1.3",
        "larastan/larastan": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\SlugGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\SlugGenerator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PhilipRehberger\\SlugGenerator\\SlugGeneratorServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
